[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.1
reloadable = true

[libraries]
linux.release.x86_64 =   "res://rust-target/release/libgodot_template.so"
windows.release.x86_64 = "res://rust-target/release/godot_template.dll"
macos.release =          "res://rust-target/release/libgodot_template.dylib"
macos.release.arm64 =    "res://rust-target/release/libgodot_template.dylib"
linux.debug.x86_64 =     "res://rust-target/debug/libgodot_template.so"
windows.debug.x86_64 =   "res://rust-target/debug/godot_template.dll"
macos.debug =            "res://rust-target/debug/libgodot_template.dylib"
macos.debug.arm64 =      "res://rust-target/debug/libgodot_template.dylib"
